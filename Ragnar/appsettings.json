{
    "ApplicationOptions": {
        //"SourceDirectory": "%USERPROFILE%\\source\\Ragnar\\",
        //"VectorStoreName": "programming_docs",

        //"SourceDirectory": "%USERPROFILE%\\source\\repos\\Obituary.Aspire\\",
        //"VectorStoreName": "Shepherd_Obit",

        "SourceDirectory": "%USERPROFILE%\\source\\repos\\WebPToPng\\",
        "VectorStoreName": "WebToPng",

        //"SourceDirectory": "%USERPROFILE%\\source\\repos\\ShepardFlock\\ShepherdFlock.Api\\",
        //"VectorStoreName": "Shepherd_Api",
        "Monitor": null,
        "CategoriesToProcess": [],
        "IncludeOriginalPrompt": false
    },
    "EmbeddingOptions": {
        "Timeout": "00:05:00",
        "Host": "localhost",
        "Port": 6334,
        "EmbeddingModel": "nomic-embed-text",
        "Dimension": 768
    },
    "FileLoadOptions": {
        "AllowedFileExtensions": [ ".csproj", ".editorconfig", ".cs", ".json" ],
        "ExcludedFiles": [ "GlobalUsings.cs", "docker-compose.yml" ],
        "ExcludedDirectories": [ "qdrant_storage", "Response", "obj", "bin", ".sonarqube", ".git", ".github", ".vs", ".config" ]
    },
    "OllamaOptions": {
        "Timeout": "00:20:00",
        "LlmModel": "qwen3.6",
        //"LlmModel": "qwen3-coder-next",
        "Port": 11434,
        "Host": "localhost"
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Polly": "Warning",
                "System": "Warning",
                "System.Net.Http.HttpClient": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Seq",
                "Args": {
                    "serverUrl": "http://localhost:5341"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log-.txt",
                    "rollingInterval": "Day",
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
                    "retainedFileCountLimit": 30
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId"
        ],
        "Properties": {
            "Application": "Ragnar"
        }
    }
}
